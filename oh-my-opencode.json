{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/master/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "openai/gpt-5.3-codex",
      "variant": "high"
    },
    "atlas": {
      "model": "openai/gpt-5.3-codex",
      "variant": "xhigh"
    },
    "prometheus": {
      "model": "openai/gpt-5.3-codex",
      "variant": "xhigh"
    },
    "metis": {
      "model": "openai/gpt-5.3",
      "variant": "high"
    },
    "momus": {
      "model": "openai/gpt-5.3",
      "variant": "medium"
    },
    "oracle": {
      "model": "openai/gpt-5.3",
      "variant": "high"
    },
    "librarian": {
      "model": "openai/gpt-5.3",
      "variant": "high"
    },
    "explore": {
      "model": "openai/gpt-5.3",
      "variant": "high"
    },
    "frontend-ui-ux-engineer": {
      "model": "openai/gpt-5.3",
      "variant": "high"
    },
    "document-writer": {
      "model": "openai/gpt-5.3",
      "variant": "high"
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.3",
      "variant": "high"
    },
    "hephaestus": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    }
  },
  "ralph_loop": {
    "enabled": true,
    "default_max_iterations": 50
  },
  "background_task": {
    "defaultConcurrency": 3
  },
  "categories": {
    "visual-engineering": {
      "model": "openai/gpt-5.3",
      "variant": "high"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.3-codex",
      "variant": "xhigh"
    },
    "artistry": {
      "model": "openai/gpt-5.3",
      "variant": "high"
    },
    "quick": {
      "model": "openai/gpt-5.3"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    },
    "writing": {
      "model": "openai/gpt-5.3",
      "variant": "high"
    },
    "deep": {
      "model": "openai/gpt-5.3-codex",
      "variant": "medium"
    }
  },
  "lsp": {
    "remark-language-server": {
      "command": [
        "remark-language-server",
        "--stdio"
      ],
      "extensions": [
        ".md",
        ".markdown"
      ]
    }
  }
}
