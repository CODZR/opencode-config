    "artistry": {
      "model": "openai/gpt-5.2"
    },
    "quick": {
      "model": "opencode/big-pickle"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.2-codex",
      "variant": "medium"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.2-codex",
      "variant": "medium"
    },
    "writing": {
      "model": "openai/gpt-5.2"
    }
  }
