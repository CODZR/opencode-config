  "task": "Task 3 burst stack runtime QA evidence",
  "scenario": "POST 7 notifications keeps maxVisible=5 with newest-first order",
  "commands": [
    "pkill -x Hammerspoon || true; open -a Hammerspoon; sleep 2",
    "TOKEN=\"${OPENCODE_NOTIFY_TOKEN:-opencode-test-token}\"; curl -sS -m 2 -o /tmp/opencode-task8/health.json -w '%{http_code}' http://127.0.0.1:17342/opencode/health -H \"x-opencode-token: $TOKEN\"",
    "for i in 1 2 3 4 5 6 7; do curl -sS -m 2 -o /tmp/opencode-task8/burst_notify_$i.json -w '%{http_code}' -X POST http://127.0.0.1:17342/opencode/notify -H \"x-opencode-token: $TOKEN\" -H \"content-type: application/json\" -d \"{\\\"id\\\":\\\"qa-burst-$i\\\",\\\"message\\\":\\\"Burst $i\\\",\\\"subtitle\\\":\\\"Task8\\\"}\"; done",
    "curl -sS -m 2 http://127.0.0.1:17342/opencode/debug/state -H \"x-opencode-token: $TOKEN\" > /tmp/opencode-task8/burst_state.json",
    "jq -e '.ok == true and (.active | length) == 5 and ([.active[].id] == [\"qa-burst-7\",\"qa-burst-6\",\"qa-burst-5\",\"qa-burst-4\",\"qa-burst-3\"]) and (.active[0].id == \"qa-burst-7\") and (.active[4].id == \"qa-burst-3\")' /tmp/opencode-task8/burst_state.json"
